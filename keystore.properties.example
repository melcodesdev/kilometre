# Local signing credentials. Copy to keystore.properties and fill in.
# keystore.properties is gitignored — never commit it.
#
# For CI builds, GitHub Actions decodes a base64-encoded copy of the .jks
# from the KEYSTORE_BASE64 secret and reads passwords from
# KEYSTORE_STORE_PASSWORD, KEYSTORE_KEY_PASSWORD, KEYSTORE_KEY_ALIAS.

storeFile=/absolute/path/to/kilometre-upload.jks
storePassword=REPLACE_ME
keyAlias=kilometre
keyPassword=REPLACE_ME
